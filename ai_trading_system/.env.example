# 秒级AI交易系统环境变量配置

# ===== 系统配置 =====
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ===== 数据库配置 =====
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=trading
CLICKHOUSE_USERNAME=trader
CLICKHOUSE_PASSWORD=trading123

# ===== 消息队列配置 =====
# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ===== 交易所API配置 =====
# 币安 (请填入您的实际API密钥)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true

# 其他交易所 (可选)
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=

# HUOBI_API_KEY=
# HUOBI_SECRET_KEY=

# ===== 交易配置 =====
TRADING_MAX_POSITION_SIZE=100000.0
TRADING_MAX_DAILY_LOSS=10000.0
TRADING_MAX_DRAWDOWN=0.05
TRADING_SLIPPAGE_TOLERANCE=0.001
TRADING_ORDER_TIMEOUT=30
TRADING_MODEL_UPDATE_INTERVAL=3600
TRADING_PREDICTION_THRESHOLD=0.6

# 支持的交易标的 (逗号分隔)
TRADING_SUPPORTED_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,ADAUSDT

# ===== 监控配置 =====
PROMETHEUS_PORT=8000
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
MONITORING_LOG_FILE=logs/trading.log
MONITORING_MAX_LATENCY_MS=500

# ===== 安全配置 =====
SECRET_KEY=your-super-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data

# ===== 性能配置 =====
MAX_WORKERS=4
QUEUE_SIZE=10000

# ===== 监控面板密码 =====
GRAFANA_PASSWORD=admin123

# ===== 部署配置 =====
# Docker相关
COMPOSE_PROJECT_NAME=ai-trading
COMPOSE_HTTP_TIMEOUT=120

# 资源限制
TRADING_SYSTEM_MEMORY_LIMIT=2g
TRADING_SYSTEM_CPU_LIMIT=1.0

# ===== 备份配置 =====
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点备份
BACKUP_RETENTION_DAYS=30

# ===== 开发配置 =====
# 仅在开发环境使用
DEV_MOCK_TRADING=false
DEV_MOCK_DATA=false
DEV_API_DELAY_MS=0